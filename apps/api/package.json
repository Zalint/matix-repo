{
  "name": "@matix/api",
  "version": "0.0.1",
  "private": true,
  "description": "Matix API — backend NestJS modulaire",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "test:e2e": "jest --config jest-e2e.config.js --runInBand",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:maas": "tsx src/db/seed-from-maas.ts",
    "db:seed:kc-users": "tsx src/db/seed-keycloak-users.ts",
    "db:seed:workflow-templates": "tsx src/db/seed-workflow-templates.ts"
  },
  "dependencies": {
    "@keycloak/keycloak-admin-client": "^26.6.1",
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "drizzle-orm": "^0.36.0",
    "jose": "5",
    "jwks-rsa": "^4.0.1",
    "nestjs-cls": "^4.4.1",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.13.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/testing": "^10.4.4",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.10",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.27.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
