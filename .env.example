# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=matix
# Compte applicatif — NON-superuser, soumis à RLS
POSTGRES_APP_USER=matix_app
POSTGRES_APP_PASSWORD=matix_app_dev
# Compte admin — pour migrations & ops cross-tenant
POSTGRES_ADMIN_USER=matix_admin
POSTGRES_ADMIN_PASSWORD=matix_admin_dev

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- API ---
API_PORT=3001
NODE_ENV=development

# --- Auth (Phase 0 dev mode) ---
# Phase 0 utilise un header X-Dev-Tenant-Id pour tester RLS sans Keycloak.
# À remplacer par JWT Keycloak en Phase 1.
DEV_AUTH_ENABLED=true

# --- Keycloak (Phase 1+) ---
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=matix
KEYCLOAK_CLIENT_ID=matix-api
KEYCLOAK_CLIENT_SECRET=

# --- Bictorys (Phase 1+) ---
BICTORYS_API_KEY=
BICTORYS_BASE_URL=https://api.bictorys.com
