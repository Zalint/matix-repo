# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=matix
# Compte applicatif — NON-superuser, soumis à RLS
POSTGRES_APP_USER=matix_app
POSTGRES_APP_PASSWORD=matix_app_dev
# Compte admin — pour migrations & ops cross-tenant
POSTGRES_ADMIN_USER=matix_admin
POSTGRES_ADMIN_PASSWORD=matix_admin_dev

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- API ---
API_PORT=3001
NODE_ENV=development

# --- Auth ---
# Mode 'dev'      : headers X-Dev-Tenant-Id / X-Dev-User-Id (Phase 0, défaut).
# Mode 'keycloak' : JWT Bearer Keycloak vérifié + lookup tenant_members en DB.
AUTH_MODE=dev

# --- Keycloak (uniquement si AUTH_MODE=keycloak) ---
KEYCLOAK_ISSUER=http://localhost:8081/realms/matix
KEYCLOAK_AUDIENCE=matix-api

# --- Bictorys (Phase 1+) ---
BICTORYS_API_KEY=
BICTORYS_BASE_URL=https://api.bictorys.com

# === n8n (workflows orchestration) ===
# URL n8n (depuis l'host : http://localhost:5678 ; depuis Docker : http://matix-n8n:5678)
N8N_URL=http://localhost:5678
# API Key n8n (Settings → n8n API → Create API Key dans l'UI n8n)
N8N_API_KEY=

# === Workflow scheduler ===
# Active le cron interne qui fire les webhooks n8n (1 = ON, sinon OFF).
WORKFLOWS_CRON_ENABLED=0
# Fuseau horaire pour interpreter les cron 'HH:MM' (default Africa/Dakar).
WORKFLOWS_CRON_TZ=Africa/Dakar

# === Service token Matix ===
# Pour les calls n8n → API Matix avec un tenant_id arbitraire (header X-Service-Token).
MATIX_SERVICE_TOKEN=
