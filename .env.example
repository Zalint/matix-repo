# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=matix
# Compte applicatif — NON-superuser, soumis à RLS
POSTGRES_APP_USER=matix_app
POSTGRES_APP_PASSWORD=matix_app_dev
# Compte admin — pour migrations & ops cross-tenant
POSTGRES_ADMIN_USER=matix_admin
POSTGRES_ADMIN_PASSWORD=matix_admin_dev

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- API ---
API_PORT=3001
NODE_ENV=development

# --- Auth ---
# Mode 'dev'      : headers X-Dev-Tenant-Id / X-Dev-User-Id (Phase 0, défaut).
# Mode 'keycloak' : JWT Bearer Keycloak vérifié + lookup tenant_members en DB.
AUTH_MODE=dev

# --- Keycloak (uniquement si AUTH_MODE=keycloak) ---
KEYCLOAK_ISSUER=http://localhost:8080/realms/matix
KEYCLOAK_AUDIENCE=matix-api

# --- Bictorys (Phase 1+) ---
BICTORYS_API_KEY=
BICTORYS_BASE_URL=https://api.bictorys.com
